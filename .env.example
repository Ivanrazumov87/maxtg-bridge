# Скопируйте этот файл в .env и заполните значения (без кавычек).
#   cp .env.example .env

# ── MAX ───────────────────────────────────────────────
# Токен веб-сессии MAX. Как получить — см. README, раздел «Шаг 2».
# ВАЖНО: используйте ОТДЕЛЬНУЮ сессию (окно инкогнито), чтобы бот не конфликтовал
# с вашим обычным входом в web.max.ru.
MAX_TOKEN=

# Необязательно: whitelist чатов MAX через запятую.
# Пусто  -> пересылаются ВСЕ чаты MAX.
# Задано -> только перечисленные чаты (ID из адресной строки web.max.ru).
MAX_CHAT_IDS=

# ── Telegram ──────────────────────────────────────────
# Токен бота от @BotFather (см. README, «Шаг 3»).
TG_BOT_TOKEN=

# ID форум-СУПЕРГРУППЫ Telegram с включёнными «Темами» (см. README, «Шаг 4»).
# Начинается с -100... Бот должен быть в группе администратором
# с правом «Управление темами».
TG_GROUP_ID=

# Необязательно: ID чата для уведомлений о состоянии бота (встал/упал).
MONITOR_ID=
